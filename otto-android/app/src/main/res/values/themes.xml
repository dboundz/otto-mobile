<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
      Pre-API 31: cold start uses android:windowBackground. API 31+ is overridden in values-v31 (android:windowSplashScreen*).
    -->
    <style name="Theme.OttoMobile.Launcher" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="windowSplashScreenBackground">@color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/driftd_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.OttoMobile.Main</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- uCrop: avoid edge-to-edge default on API 35+ (toolbar/menu would draw under status bar). -->
    <style name="Theme.Otto.UCrop" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
    </style>

    <!-- Applied after the system splash via postSplashScreenTheme (see Theme.OttoMobile.Launcher). -->
    <style name="Theme.OttoMobile.Main" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/otto_window_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
