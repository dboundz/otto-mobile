# Copy to keystore.properties (gitignored) and fill in. Paths are relative to this folder (otto-android).
#
# Create a keystore (one-time), e.g.:
#   keytool -genkey -v -keystore upload.keystore -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=upload.keystore
storePassword=your-store-password
keyAlias=upload
keyPassword=your-key-password
