<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ requires a splash "icon" in the center; keep it invisible so full-bleed art from windowSplashScreenBackground shows. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <size
                android:width="24dp"
                android:height="24dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
